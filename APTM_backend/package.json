{
  "name": "alpha-phoenix-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "postinstall": "node -e \"const fs=require('fs');['uploads/avatars','uploads/banners','uploads/gallery','uploads/posts','uploads/documents','uploads/address-proofs'].forEach(d=>{if(!fs.existsSync(d))fs.mkdirSync(d,{recursive:true})})\"",
    "clean": "rm -rf node_modules package-lock.json && npm cache clean --force",
    "reinstall": "npm run clean && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^9.11.0",
    "jsonwebtoken": "^9.0.2",
    "metaapi.cloud-sdk": "^28.0.0",
    "mongodb": "6.8.0",
    "mongoose": "8.5.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.13",
    "pg": "^8.12.0",
    "sequelize": "^6.37.3",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}