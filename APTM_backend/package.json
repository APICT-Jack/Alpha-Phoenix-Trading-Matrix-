{
  "$schema": "https://json.schemastore.org/package",
  "name": "alpha-phoenix-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "postinstall": "node -e \"const fs=require('fs');['uploads/avatars','uploads/banners','uploads/gallery','uploads/posts'].forEach(d=>{if(!fs.existsSync(d))fs.mkdirSync(d,{recursive:true})})\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "google-auth-library": "^10.4.0",
    "jsonwebtoken": "^9.0.2",
    "metaapi.cloud-sdk": "^29.3.3",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.2",
    "multer": "^1.4.5-lts.2",
    "multer-storage-cloudinary": "^2.2.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.15.6",
    "sequelize": "^6.37.7",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
